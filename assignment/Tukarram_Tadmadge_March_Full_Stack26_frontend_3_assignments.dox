<!DOCTYPE html>
<html>
<head>
    <title>Form Input Controls</title>
</head>

<body style="font-family: Arial; margin: 40px;">

    <h2>Form Input Controls Example</h2>

    <form>

        <!-- Basic Inputs -->
        Name: <input type="text" placeholder="Enter your name">
        
        Password: <input type="password" placeholder="Enter your password">
        
        Email: <input type="email" placeholder="Enter your email">
        <br><br>

        Age: <input type="number" value="18">

        Rating: <input type="range">

        Date of Birth: <input type="date">
        <br><br>

        Time: <input type="time">

        Image: <input type="file">
        <br><br>

        Week: <input type="week">
        <br><br>

        Month: <input type="month">
        <br><br>

        Datetime-Local: <input type="datetime-local">
        <br><br>

        URL: <input type="url">
        <br><br>

        Search: <input type="search">
        <br><br>

        <!-- Radio Buttons -->
        Gender:<br>
        <input type="radio" name="gender" checked> Male
        <input type="radio" name="gender"> Female
        <br><br>

        <!-- Checkboxes -->
        Interests:<br>
        <input type="checkbox"> Reading
        <input type="checkbox" checked> Sports
        <br><br>

        <!-- Dropdown -->
        Country:
        <select>
            <option>United States</option>
            <option>India</option>
            <option>UK</option>
        </select>
        <br><br>

        <!-- Textarea -->
        Message:<br>
        <textarea rows="4" cols="40" placeholder="Enter your message"></textarea>
        <br><br>

        <!-- Submit -->
        <input type="submit" value="Submit">

    </form>

</body>
</html>